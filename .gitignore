# ========================
# 1. 用户指定规则
# ========================
# 忽略所有的 yaml 配置文件 (防止配置文件泄露)
*.yaml
*.yml

# ========================
# 2. Python 基础排除项
# ========================
# 忽略编译文件和缓存
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境 (极其重要，不要把几百MB的包传上 Git)
venv/
env/
.venv/

# ========================
# 3. 业务与安全隐私项
# ========================
# 忽略环境变量文件 (极其重要，防止 DeepSeek/通义大模型 API Key 泄露！)
.env
.env.*

# 忽略 Chroma 向量数据库的本地数据文件夹
chroma_data/

# ========================
# 4. IDE 工作区文件
# ========================
.idea/
.vscode/
*.swp
.DS_Store